# =============================================================================
# Sunseeker — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Mapbox
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# -----------------------------------------------------------------------------
# Solar Microservice (server-side only — never expose to the browser)
# -----------------------------------------------------------------------------
SOLAR_SERVICE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database (used by migration and ingestion scripts directly)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sunseeker

# -----------------------------------------------------------------------------
# Auth — Google OAuth (optional, for user accounts)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
